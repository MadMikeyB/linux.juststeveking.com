---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getDistroIcon } from '../../utils/icons';

export async function getStaticPaths() {
  const distros = await getCollection('distros');
  return distros.map(distro => ({
    params: { slug: distro.id },
    props: { distro },
  }));
}

const { distro } = Astro.props;
const { data } = distro;

const releaseLabel = {
  rolling: 'Rolling release',
  fixed: 'Fixed release',
  lts: 'Long-term support (LTS)',
}[data.release_model];

const attributeLabels: Record<string, string> = {
  beginner_friendly: 'Beginner-friendly',
  hardware_requirements: 'Hardware requirements',
  stability: 'Stability',
  customizability: 'Customizability',
  out_of_box: 'Out-of-the-box experience',
  documentation: 'Documentation quality',
  community: 'Community size',
  gaming: 'Gaming support',
  development: 'Development tooling',
  privacy: 'Privacy posture',
};

const attributeEntries = Object.entries(data.attributes) as [keyof typeof data.attributes, number][];
const icon = getDistroIcon(data.icon_slug);
---

<Layout title={`${data.name} — DistroFind`} description={data.tagline}>
  <div class="container page" style={data.color ? `--distro-color: ${data.color}` : ''}>
    <a href="/distros" class="back-link">
      ← All distributions
    </a>

    <header class="distro-header">
      <div class="distro-icon-lg">
        {icon ? (
          <svg viewBox="0 0 24 24" class="distro-logo-lg" aria-hidden="true">
            <path d={icon.path} />
          </svg>
        ) : (
          <span class="distro-initial-lg">{data.name[0]}</span>
        )}
      </div>
      <div class="distro-header-text">
        <h1>{data.name}</h1>
        <p class="distro-tagline-lg">{data.tagline}</p>
        <div class="distro-meta">
          {data.based_on && <span class="badge">↗ {data.based_on}</span>}
          <span class="badge">{releaseLabel}</span>
          {data.use_cases.map(uc => (
            <span class="badge badge-use">{uc}</span>
          ))}
        </div>
      </div>
      <a href={data.website} class="btn btn-outline external-link" target="_blank" rel="noopener noreferrer">
        Visit website
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </header>

    <div class="content-grid">
      <div class="main-content">
        <section class="section">
          <p class="section-heading">About</p>
          <p class="description">{data.description}</p>
        </section>

        <section class="section">
          <p class="section-heading">Attribute scores</p>
          <p class="section-note">Curated estimates on a 1–5 scale. Higher is always more of that quality.</p>
          <div class="attributes-list" id="attributes-list">
            {attributeEntries.map(([key, value], i) => (
              <div class="attribute-row" data-index={i}>
                <span class="attribute-label">{attributeLabels[key] ?? key}</span>
                <div class="attribute-bar-track">
                  <div
                    class="attribute-bar-fill"
                    style={`--bar-w: ${(value / 5) * 100}%`}
                    data-index={i}
                  ></div>
                </div>
                <span class="attribute-value">{value}/5</span>
              </div>
            ))}
          </div>
        </section>
      </div>

      <aside class="sidebar">
        <div class="info-card">
          <h3>Desktop environments</h3>
          <ul class="info-list">
            {data.desktop_environments.map(de => <li>{de}</li>)}
          </ul>
        </div>

        <div class="info-card">
          <h3>Package managers</h3>
          <ul class="info-list">
            {data.package_managers.map(pm => <li><code>{pm}</code></li>)}
          </ul>
        </div>

        <div class="info-card">
          <h3>Desktop styles</h3>
          <div class="tags">
            {data.desktop_styles.map(s => <span class="badge">{s}</span>)}
          </div>
        </div>

        <div class="info-card">
          <h3>Use cases</h3>
          <div class="tags">
            {data.use_cases.map(uc => <span class="badge badge-use">{uc}</span>)}
          </div>
        </div>

        <a href="/finder" class="finder-cta btn btn-primary">
          Find distributions like this one
        </a>
      </aside>
    </div>
  </div>
</Layout>

<script>
  function initBars() {
    const bars = document.querySelectorAll<HTMLElement>('.attribute-bar-fill');
    if (!bars.length) return;

    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const bar = entry.target as HTMLElement;
          const idx = Number(bar.dataset.index ?? 0);
          // Stagger each bar by 60ms
          setTimeout(() => bar.classList.add('animated'), idx * 60);
          observer.unobserve(bar);
        });
      },
      { threshold: 0.2 }
    );

    bars.forEach(bar => observer.observe(bar));
  }

  // Re-run after View Transitions navigation
  initBars();
  document.addEventListener('astro:page-load', initBars, { once: true });
</script>

<style>
  .page {
    padding: 2rem 0 5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-subtle);
    margin-bottom: 2rem;
    transition: color var(--transition);
    letter-spacing: 0.01em;
  }

  .back-link:hover { color: var(--text-muted); }

  /* ── Distro header ── */
  .distro-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-subtle);
    flex-wrap: wrap;
  }

  .distro-icon-lg {
    flex-shrink: 0;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--distro-color, var(--border)) 50%, transparent);
    background: color-mix(in srgb, var(--distro-color, var(--primary)) 10%, var(--bg-elevated));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .distro-logo-lg {
    width: 38px;
    height: 38px;
    fill: var(--distro-color, var(--text-muted));
  }

  .distro-initial-lg {
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--distro-color, var(--text-muted));
    letter-spacing: -0.03em;
  }

  .distro-header-text {
    flex: 1;
    min-width: 0;
  }

  .distro-header-text h1 {
    font-size: 1.9rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 0.3rem;
  }

  .distro-tagline-lg {
    color: var(--text-muted);
    margin-bottom: 0.875rem;
    font-size: 1rem;
    line-height: 1.4;
  }

  .distro-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .badge-use {
    color: var(--primary);
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
    background: color-mix(in srgb, var(--primary) 8%, transparent);
  }

  .external-link {
    align-self: flex-start;
    white-space: nowrap;
    margin-top: 0.25rem;
  }

  /* ── Content grid ── */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 268px;
    gap: 2.5rem;
    align-items: start;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    margin-bottom: 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-note {
    font-size: 0.8rem;
    color: var(--text-subtle);
    margin-bottom: 1.125rem;
  }

  .description {
    color: var(--text-muted);
    line-height: 1.8;
    font-size: 0.95rem;
  }

  /* ── Attribute bars ── */
  .attributes-list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .attribute-row {
    display: grid;
    grid-template-columns: 190px 1fr 2.75rem;
    align-items: center;
    gap: 1rem;
  }

  .attribute-label {
    font-size: 0.84rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .attribute-bar-track {
    height: 5px;
    background: var(--bg-elevated);
    border-radius: 999px;
    overflow: hidden;
  }

  .attribute-bar-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(
      90deg,
      var(--distro-color, var(--primary)),
      color-mix(in srgb, var(--distro-color, var(--primary)) 60%, var(--primary-hover))
    );
    border-radius: 999px;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .attribute-bar-fill.animated {
    width: var(--bar-w);
  }

  .attribute-value {
    font-size: 0.75rem;
    color: var(--text-subtle);
    text-align: right;
    font-family: var(--font-mono);
    font-weight: 600;
  }

  /* ── Sidebar ── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: sticky;
    top: 5rem;
  }

  .info-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 0.875rem 1rem;
  }

  .info-card h3 {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--text-subtle);
    margin-bottom: 0.625rem;
  }

  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .info-list li {
    font-size: 0.84rem;
    color: var(--text-muted);
  }

  .info-list code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: var(--bg-elevated);
    padding: 0.1rem 0.45rem;
    border-radius: 5px;
    color: var(--accent);
    border: 1px solid var(--border-subtle);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .finder-cta {
    justify-content: center;
    padding: 0.7rem;
    font-size: 0.84rem;
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .sidebar { position: static; }

    .attribute-row {
      grid-template-columns: 130px 1fr 2.5rem;
    }
  }
</style>
